# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here
JWT_SECRET=generate-with-node-e-console-log-require-crypto-randomBytes-64-toString-hex

# Database (PostgreSQL)
# On Railway: do NOT set a literal value here. In the Railway dashboard, set
#   DATABASE_URL = ${{Postgres.DATABASE_URL}}
# (the private connection string, injected at runtime).
#
# For local development, point at a local Postgres OR the Railway PUBLIC url
# (Railway -> Postgres service -> Variables -> DATABASE_PUBLIC_URL).
# Must start with postgresql:// — no surrounding quotes, no trailing newline.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Production
NODE_ENV=production
CLIENT_URL=https://your-railway-url.up.railway.app

# Netlify Live Deploy (enables live website updates via agents)
# Get from: app.netlify.com/user/applications → Personal access tokens → New token
NETLIFY_TOKEN=your-netlify-personal-access-token

# Stripe (enables paid plan upgrades — required for paywall to work)
# Get from: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_or_sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Create 3 recurring Prices in Stripe Dashboard -> Products, then paste their price IDs:
STRIPE_PRICE_STARTER=price_your-starter-price-id
STRIPE_PRICE_ACTIVE=price_your-active-price-id
STRIPE_PRICE_AUTOPILOT=price_your-autopilot-price-id
